# === ARGOS Configuration ===

# --- LLM Backend ---
LLM_BACKEND=groq
GROQ_API_KEY=your_groq_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# OLLAMA_URL=http://localhost:11434/api/chat

# --- Voice (optional) ---
ENABLE_VOICE=False

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Google OAuth2 (for Gmail HITL workflows) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# --- n8n Workflow Engine ---
N8N_API_KEY="<n8n_api_key_from_dashboard>"

# ====== NGROK WEBHOOK CONFIGURATION (OPTIONAL BUT RECOMMENDED) ======
# Register on ngrok.com for an Auth Token and a Free Static Domain
NGROK_AUTHTOKEN=""
NGROK_DOMAIN=""
# --- Networking (Internal) ---
N8N_HOST=localhost   # Set to "n8n" when running clear/inject scripts from inside Docker
N8N_PORT=5678

# --- Security ---
# Generate a secure string for internal API authentication
ARGOS_API_KEY=""

# --- Telegram Chat Bot (Public Chat Module) ---
TELEGRAM_CHAT_BOT_TOKEN=your_new_chat_bot_token_here
ADMIN_CHAT_ID=your_telegram_chat_id_here

# --- Logic Settings ---
MAX_TOOL_LOOPS=10