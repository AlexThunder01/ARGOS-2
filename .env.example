# === ARGOS Configuration ===

# --- Base LLM (Text & Reasoning) ---
LLM_BACKEND=openai-compatible
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
LLM_LIGHTWEIGHT_MODEL=llama-3.1-8b-instant

# === Examples for common providers ===
# OpenAI:      LLM_BASE_URL=https://api.openai.com/v1              LLM_MODEL=gpt-4o
# Mistral:     LLM_BASE_URL=https://api.mistral.ai/v1              LLM_MODEL=mistral-large-latest
# Ollama:      LLM_BASE_URL=http://localhost:11434/v1              LLM_MODEL=llama3          LLM_API_KEY=ollama
# vLLM:        LLM_BASE_URL=http://localhost:8000/v1               LLM_MODEL=your-model      LLM_API_KEY=none
# LM Studio:   LLM_BASE_URL=http://localhost:1234/v1               LLM_MODEL=loaded-model    LLM_API_KEY=lm-studio
# Anthropic:   LLM_BACKEND=anthropic  LLM_API_KEY=your_key         LLM_MODEL=<anthropic-model-name>

# --- Vision LLM ---
VISION_BASE_URL=https://api.groq.com/openai/v1
VISION_API_KEY=your_groq_api_key_here
VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Embeddings (RAG) ---
EMBEDDING_BASE_URL=https://api.groq.com/openai/v1
EMBEDDING_API_KEY=your_groq_api_key_here
EMBEDDING_MODEL=nomic-embed-text-v1.5
EMBEDDING_DIM=768

# --- STT (Speech-to-Text) ---
# Options: groq | openai | custom
STT_BACKEND=groq
# STT_CUSTOM_URL=https://your-whisper-server.com/v1/audio/transcriptions
# STT_CUSTOM_API_KEY=your_key


# --- Voice (optional) ---
ENABLE_VOICE=False

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Google OAuth2 (for Gmail HITL workflows) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# --- n8n Workflow Engine ---
N8N_API_KEY="<n8n_api_key_from_dashboard>"

# ====== NGROK WEBHOOK CONFIGURATION (OPTIONAL BUT RECOMMENDED) ======
# Register on ngrok.com for an Auth Token and a Free Static Domain
NGROK_AUTHTOKEN=""
NGROK_DOMAIN=""
# --- Networking (Internal) ---
N8N_HOST=localhost   # Set to "n8n" when running clear/inject scripts from inside Docker
N8N_PORT=5678

# --- Security ---
# Generate a secure string for internal API authentication
ARGOS_API_KEY=""

# --- Telegram Chat Bot (Public Chat Module) ---
TELEGRAM_CHAT_BOT_TOKEN=your_new_chat_bot_token_here
ADMIN_CHAT_ID=your_telegram_chat_id_here

# --- Logic Settings ---
MAX_TOOL_LOOPS=10

# --- Security Middleware ---
# Enables the Paranoid Judge on all API endpoints (cross-cutting input validation)
ARGOS_PARANOID_MODE=false

# --- Database ---
# Backend: 'postgres' (production, Docker) or 'sqlite' (local dev without Docker)
DB_BACKEND=postgres
# PostgreSQL connection string (only needed when DB_BACKEND=postgres)
DATABASE_URL=postgresql://argos:argos_secret@argos-db:5432/argos
POSTGRES_PASSWORD=argos_secret

# --- Observability (OpenTelemetry + Jaeger) ---
# gRPC endpoint for the OTLP collector (Jaeger)
OTEL_EXPORTER_OTLP_ENDPOINT=http://argos-jaeger:4317

# Rate Limiting (Protections API & Telegram)
RATE_LIMIT_PER_HOUR=50
RATE_LIMIT_PER_MINUTE=10
OTEL_SERVICE_NAME=argos-api

# --- Docker Sandbox Isolation ---
# Docker Socket Proxy for secure code execution
DOCKER_HOST=tcp://argos-docker-proxy:2375
# Host-side path to the workspace directory (for Docker volume mounts)
HOST_WORKSPACE_DIR=${PWD}/workspace
# Container-side path to the workspace directory
WORKSPACE_DIR=./workspace