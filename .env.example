# === ARGOS Configuration ===

# --- LLM Backend ---
LLM_BACKEND=groq
GROQ_API_KEY=your_groq_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# OLLAMA_URL=http://localhost:11434/api/chat

# --- Voice (optional) ---
ENABLE_VOICE=False

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- n8n Workflow Engine ---
N8N_API_KEY="<n8n_api_key_from_dashboard>"

# ====== NGROK WEBHOOK CONFIGURATION (OPTIONAL BUT RECOMMENDED) ======
# Register on ngrok.com for an Auth Token and a Free Static Domain
NGROK_AUTHTOKEN=""
NGROK_DOMAIN=""